{
  "manifest_version": 3,
  "name": "BJAssist — Blackjack & Video Poker Strategy",
  "version": "0.3.0",
  "description": "Shows the mathematically optimal blackjack and video poker play with exact odds. Read-only: it advises, you decide.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "BJAssist",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://live.dodopayments.com/*",
    "https://xlstduhdanyfqnbiziym.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.stake.com/*",
        "https://*.stake.us/*",
        "https://*.stake.ac/*",
        "https://*.stake.bet/*",
        "https://*.stake.games/*",
        "https://*.shuffle.com/*",
        "https://*.shuffle.us/*"
      ],
      "js": ["src/strategy.js", "src/video-poker.js", "src/site-configs.js", "src/license.js", "src/content.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://bjassist.com/*", "https://www.bjassist.com/*"],
      "js": ["src/license.js", "src/web-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
